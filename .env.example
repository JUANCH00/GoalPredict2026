# Plantilla de variables de entorno para GoalPredict 2026.
# Copia este archivo a `.env` y ajusta los valores antes de levantar el stack.
#
# Las variables aquí se leen tanto por el backend (vía pydantic-settings)
# como por docker-compose (vía `env_file`).
#
# ⚠️  `.env` NO debe commitearse al repo. `.env.example` sí.

# --- Postgres ---
POSTGRES_USER=goalpredict
POSTGRES_PASSWORD=cambia-esto-en-prod
POSTGRES_DB=goalpredict

# --- Backend ---
# URL completa para SQLAlchemy. En docker-compose el host es el nombre del
# servicio (`db`). Para correr el backend localmente sin docker, cambia
# `db` por `localhost` (y asegúrate de tener Postgres corriendo).
DATABASE_URL=postgresql+psycopg2://goalpredict:cambia-esto-en-prod@db:5432/goalpredict

# Genera un secreto largo y aleatorio en producción:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production-this-is-not-a-real-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Usuarios demo (creados solo si la tabla users está vacía) ---
DEMO_FREE_USERNAME=free_user
DEMO_FREE_PASSWORD=free123
DEMO_PREMIUM_USERNAME=premium_user
DEMO_PREMIUM_PASSWORD=premium123
